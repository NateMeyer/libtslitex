{
    "$id": "https://example.com/schemas/hwid",
    "title": "Hardware Identity",
    "type": "object",
    "properties": {
        "version": {
            "type": "integer",
            "minimum": 1
        },
        "serial": {
            "type": "string",
            "maxLength": 256
        },
        "boardRevision": {
            "type": "number"
        },
        "buildConfiguration": {
            "type": "string",
            "maxLength": 256
        },
        "buildDate": {
            "type": "string",
            "maxLength": 256,
            "description": "UTC date/time in ISO 8601 format"
        },
        "manufacturingSignature": {
            "type": "string",
            "maxLength": 256
        }
    },
    "required": [
        "version",
        "serial"
    ]
}